# ── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=8081

# ── Database (local Docker / AWS RDS / Aurora) ────────────
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password_here
DB_NAME=gamedatabase

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-string
JWT_REFRESH_SECRET=replace-with-another-64-byte-hex-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# ── Google OAuth ──────────────────────────────────────────
# Get from https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=https://your-bucket.s3-website-us-east-1.amazonaws.com

# ── React (used during `npm run build`) ──────────────────
REACT_APP_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
