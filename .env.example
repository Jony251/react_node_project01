# Copy this file to .env and fill in the values
NODE_ENV=production
PORT=8081

# Database (local Docker or AWS RDS/Aurora)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_strong_password_here
DB_NAME=gamedatabase

# JWT – MUST be changed to a long random string in production
JWT_SECRET=replace-with-a-very-long-random-secret

# CORS – set to your S3 static site / CloudFront URL
FRONTEND_URL=https://your-bucket.s3-website-us-east-1.amazonaws.com
